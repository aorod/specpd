# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env

# Token do Azure DevOps (Personal Access Token)
# Permissão mínima necessária: Analytics → Read
ADO_TOKEN=seu_personal_access_token_aqui

# Organização e projetos do Azure DevOps
ADO_ORG=sua_organizacao
ADO_PROJECT_2026=nome_do_projeto_roadmap_encodado
ADO_PROJECT_ED=nome_do_projeto_ed_encodado

# Porta do servidor (opcional, padrão: 3001)
PORT=3001

# TTL do cache SQLite em minutos (opcional, padrão: 30)
CACHE_TTL_MINUTES=30

# Chave secreta para assinar tokens JWT
# GERAR COM: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_segura_aqui

# Origem permitida pelo CORS (URL do frontend)
ALLOWED_ORIGIN=http://localhost:5173
